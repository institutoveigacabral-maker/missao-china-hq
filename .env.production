# Production Environment Variables
VITE_APP_TITLE=Missão China HQ
VITE_APP_VERSION=2.0.0
VITE_API_URL=https://api.mochaai.com
VITE_CDN_URL=https://cdn.mochaai.com
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Build optimizations
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_PREFETCH=true
VITE_ENABLE_SW=true

# Feature flags
VITE_FEATURE_PWA=true
VITE_FEATURE_OFFLINE=true
VITE_FEATURE_PUSH_NOTIFICATIONS=true
