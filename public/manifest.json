    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],

  "screenshots": [
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard Principal"
    },
    {
      "src": "/screenshots/mobile-1.png", 
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Playbook Técnico Mobile"
    }
  ],

  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Visão geral dos KPIs",
      "url": "/",
      "icons": [{ "src": "/icons/shortcut-dashboard.png", "sizes": "96x96" }]
    },
    {
      "name": "SKUs",
      "short_name": "SKUs", 
      "description": "Playbook Técnico IoT",
      "url": "/playbook",
      "icons": [{ "src": "/icons/shortcut-skus.png", "sizes": "96x96" }]
    },
    {
      "name": "Fornecedores",
      "short_name": "Suppliers",
      "description": "Gestão de fornecedores",
      "url": "/suppliers", 
      "icons": [{ "src": "/icons/shortcut-suppliers.png", "sizes": "96x96" }]
    },
    {
      "name": "Compliance",
      "short_name": "Compliance",
      "description": "Regulamentações 2025",
      "url": "/regulations",
      "icons": [{ "src": "/icons/shortcut-compliance.png", "sizes": "96x96" }]
    }
  ],

  "prefer_related_applications": false,
  "related_applications": [],

  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": [".csv", ".xlsx", ".pdf", ".png", ".jpg"]
        }
      ]
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+chinaq",
      "url": "/handle-protocol?url=%s"
    }
  ]
}
