{
  "name": "Missão China HQ - Dashboard Executivo",
  "short_name": "China HQ",
  "description": "Plataforma completa para gestão de operações China ↔ Brasil/Portugal",
  "version": "2.0.0",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
