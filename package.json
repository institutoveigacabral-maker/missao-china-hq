{
  "name": "missao-china-hq",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@hono/zod-validator": "^0.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/glob": "^9.0.0",
    "@vitest/ui": "^3.2.4",
    "axios": "^1.12.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cssnano": "^7.1.1",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.1.0",
    "glob": "^11.0.3",
    "hono": "4.7.7",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.554.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-is": "^19.2.0",
    "react-router": "^7.5.3",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.2.1",
    "rollup-plugin-visualizer": "^6.0.4",
    "tailwind-merge": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.0",
    "@eslint/js": "9.25.1",
    "@getmocha/vite-plugins": "latest",
    "@getmocha/users-service": "^0.0.4",
    "@types/node": "^24.7.2",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "9.25.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "15.15.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "^7.1.3",
    "wrangler": "^4.33.0"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc -b && vite build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:staging": "tsc && vite build --mode staging",
    "build:production": "NODE_ENV=production npm run build",
    "build:preview": "npm run build && vite preview",
    "preview": "vite preview",
    "preview:analyze": "npm run build:analyze && vite preview",
    "perf:audit": "lighthouse http://localhost:3001 --output=html --output-path=./perf-audit.html",
    "perf:bundle": "npm run build:analyze",
    "perf:test": "npm run build && npm run preview & sleep 5 && npm run perf:audit",
    "optimize:images": "imagemin src/assets/images/* --out-dir=src/assets/images/optimized",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:build": "rm -rf dist && npm run build",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "analyze": "ANALYZE=true vite build && echo '📊 Bundle analysis saved to dist/stats.html'",
    "analyze:serve": "npm run analyze && npx serve dist",
    "analyze:lazy": "ANALYZE=true LAZY_ANALYSIS=true vite build && echo '⚡ Lazy loading analysis complete'",
    "performance": "npm run build && npm run analyze:serve",
    "bundle:size": "npm run build && du -sh dist/*",
    "preload:test": "npm run build && echo '🔄 Testing preload strategy...'",
    "type-check": "tsc --noEmit",
    "health-check": "tsx scripts/code-health-analyzer.ts",
    "health-check:quick": "node scripts/simple-health-check.js",
    "health-report": "node scripts/health-check-generator.cjs",
    "quality:gates": "npm run type-check && npm run lint && npm run build && npm run health-check",
    "quality:pre-commit": "npm run type-check && npm run lint:fix && npm run build",
    "quality:audit": "npm audit --audit-level=moderate && npm run health-check",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  }
}
