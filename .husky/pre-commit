#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running code health checks..."

# Quick TypeScript check
echo "📝 Checking TypeScript..."
npx tsc --noEmit

if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed!"
  exit 1
fi

# ESLint check
echo "🧹 Running ESLint..."
npm run lint

if [ $? -ne 0 ]; then
  echo "❌ ESLint check failed!"
  exit 1
fi

# Build check
echo "🏗️ Testing build..."
npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build check failed!"
  exit 1
fi

# Quick health check
echo "🩺 Running health analysis..."
npm run health-check:quick

if [ $? -ne 0 ]; then
  echo "❌ Health check failed!"
  exit 1
fi

echo "✅ All code health checks passed!"
echo "🚀 Ready to commit!"
